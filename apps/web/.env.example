# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram bot (docket capture via @BotFather bot)
# TELEGRAM_BOT_TOKEN — token from /newbot
# TELEGRAM_WEBHOOK_SECRET — random string; passed to setWebhook as `secret_token`
# TELEGRAM_ALLOWED_CHATS — comma-separated list of chat IDs allowed to post /docket
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHATS=
